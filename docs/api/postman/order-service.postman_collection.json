{
  "info": {
    "name": "Enterprise Order Platform - Order Service",
    "_postman_id": "f9f9c8d7-2ab2-4a90-9b41-order-service",
    "description": "Collection dos endpoints do Order Service (Story-009).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8083",
      "type": "string"
    },
    {
      "key": "customerId",
      "value": "00000000-0000-0000-0000-000000000021",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "00000000-0000-0000-0000-000000000022",
      "type": "string"
    },
    {
      "key": "reservationRef",
      "value": "00000000-0000-0000-0000-000000000023",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('orderId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/orders",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [\n    {\n      \"skuId\": \"11111111-1111-1111-1111-111111111111\",\n      \"productNameSnapshot\": \"Camiseta Premium\",\n      \"skuNameSnapshot\": \"Camiseta Premium Preta M\",\n      \"attributesSnapshot\": {\n        \"color\": \"black\",\n        \"size\": \"M\"\n      },\n      \"quantity\": 2,\n      \"unitPriceSnapshot\": 25.00,\n      \"discountSnapshot\": 5.00,\n      \"lineTotalSnapshot\": 40.00\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Reserve Order Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/reserve-stock",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reservationRefs\": [\n    \"{{reservationRef}}\"\n  ]\n}"
            }
          }
        },
        {
          "name": "Start Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/start-payment"
          }
        },
        {
          "name": "Mark Order Paid",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/mark-paid"
          }
        },
        {
          "name": "Confirm Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/confirm"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}/cancel"
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/orders/{{orderId}}"
          }
        },
        {
          "name": "List Orders By Customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/customers/{{customerId}}/orders"
          }
        }
      ]
    }
  ]
}

