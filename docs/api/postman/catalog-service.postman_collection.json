{
  "info": {
    "name": "Enterprise Order Platform - Catalog Service",
    "_postman_id": "f9f9c8d7-2ab2-4a90-9b41-catalog-service",
    "description": "Collection dos endpoints do Catalog Service (Story-007).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "apiUsername",
      "value": "",
      "type": "string"
    },
    {
      "key": "apiPassword",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "00000000-0000-0000-0000-000000000001",
      "type": "string"
    },
    {
      "key": "skuId",
      "value": "00000000-0000-0000-0000-000000000002",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('productId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Camiseta Basica\",\n  \"description\": \"Camiseta 100% algodao\",\n  \"status\": \"INACTIVE\",\n  \"brandId\": \"11111111-1111-1111-1111-111111111111\",\n  \"categoryId\": \"22222222-2222-2222-2222-222222222222\",\n  \"specifications\": { \"material\": \"algodao\" },\n  \"images\": [\"https://cdn.exemplo.com/img1.jpg\"]\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/products/{{productId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Camiseta Basica Premium\",\n  \"description\": \"Camiseta premium\",\n  \"brandId\": \"11111111-1111-1111-1111-111111111111\",\n  \"categoryId\": \"22222222-2222-2222-2222-222222222222\",\n  \"specifications\": { \"material\": \"algodao\", \"fit\": \"regular\" },\n  \"images\": [\"https://cdn.exemplo.com/img1.jpg\", \"https://cdn.exemplo.com/img2.jpg\"]\n}"
            }
          }
        },
        {
          "name": "Change Product Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/products/{{productId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "List Active Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products?page=0&size=20"
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}"
          }
        },
        {
          "name": "List Product Skus",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/products/{{productId}}/skus"
          }
        },
        {
          "name": "Add Sku",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.collectionVariables.set('skuId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/products/{{productId}}/skus",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sellerCode\": \"SELLER-001\",\n  \"ean\": \"7890000000001\",\n  \"attributes\": { \"color\": \"black\", \"size\": \"M\" },\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        },
        {
          "name": "Update Sku",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/products/{{productId}}/skus/{{skuId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sellerCode\": \"SELLER-001-NEW\",\n  \"ean\": \"7890000000002\",\n  \"attributes\": { \"color\": \"white\", \"size\": \"G\" },\n  \"status\": \"ACTIVE\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Skus",
      "item": [
        {
          "name": "Get Sku",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/skus/{{skuId}}"
          }
        }
      ]
    }
  ]
}
